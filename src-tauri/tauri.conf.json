{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BRD Tasks",
  "version": "0.2.0",
  "identifier": "com.breadriuss.tasks-desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "BRD Tasks",
        "width": 360,
        "height": 520,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI1RjM0QTkyQjYyM0I4RjkKUldUNXVDTzJra3J6dFFlTzlyVVRoZXd2QWM3RW9nM0NkcmdrSkY4TU00Z2dGWFhwWmlUTHJzMmcK",
      "endpoints": [
        "https://apimalet.breadriuss.com/updates/updater.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
